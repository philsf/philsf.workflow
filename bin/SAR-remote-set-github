#!/bin/bash

# ************************************************************
# Script:   SAR-remote-set-github
# Purpose:  Create a new private GitHub repository, push local contents,
#           and initialize standard issue tracking boilerplate for the project.
#
# Note:     N/A
#
# Version:  0.xx.x
# Author:   Felipe Figueiredo
# Created:  2025-11-11
#
# ************************************************************
# QC Date:  YYYY-MM-DD
# ************************************************************

# Extracts the current directory name (e.g., 'SAR-2024-042-MM')
SAR=${PWD##*/} # local dir
# Extracts the project code (e.g., '2024-042-MM')
SAR_CODE=${SAR/SAR-/""}

# Ensure the terminal uses the English locale for consistent Git/gh output.
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

echo "Project Directory: $SAR"
echo "Project Code: $SAR_CODE"

# Use gh CLI to create the remote repo, set origin, and push current branch.
gh repo create philsf-biostat/$SAR --private --push --source=. --remote=origin

# Create the standard set of issues that mirror the R script workflow.

# Repository Setup
gh issue create --title "Repository Setup Check" --body-file ~/usr/SAR/QC-Checklist-1-Project-Setup.md

# Initial Pipeline Setup
gh issue create --title "Initial Pipeline Setup Check" --body-file ~/usr/SAR/QC-Checklist-2-Scripts-Setup.md

# SAP development
gh issue create --title "SAP development Checklist" --body-file ~/usr/SAR/QC-Checklist-3-SAP.md

# Analysis development: Data, Models, Tables and Figures
gh issue create --title "Analysis: Data, Models, Tables and Figures Check" --body-file ~/usr/SAR/QC-Checklist-4-Analysis.md

# Report development
gh issue create --title "Report development Checklist" --body-file ~/usr/SAR/QC-Checklist-5-SAR.md

# Project Close-out
gh issue create --title "Project Close-out Check" --body-file ~/usr/SAR/QC-Checklist-6-Project-Close-out.md
